<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<system.webServer>

		<!-- ✅ خليه يشغّل Modules على كل الريكويستات -->
		<modules runAllManagedModulesForAllRequests="true">
			<!-- ✅ WebDAV ساعات بيمسك OPTIONS/PUT/DELETE ويمنعها -->
			<remove name="WebDAVModule" />
		</modules>

		<handlers>
			<remove name="WebDAV" />
		</handlers>

	</system.webServer>
</configuration>
